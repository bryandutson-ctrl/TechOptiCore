---
const year = new Date().getFullYear();
---

<footer style="background-color: #1c1c1c; border-top: 1px solid #2a2a2a; padding: 3rem 1.5rem 2rem;">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">

      <!-- Brand -->
      <div>
        <a href="/" style="display: inline-block; margin-bottom: 0.75rem;">
          <img src="/logo.png" alt="TechOptiCore LLC" style="height: 132px; width: auto;" />
        </a>
        <p style="color: #9ca3af; font-size: 0.9rem; line-height: 1.6;">
          Fractional IT leadership and strategic technology consulting for financial services and mid-market organizations.
        </p>
      </div>

      <!-- Links -->
      <div>
        <p style="color: #ffffff; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem;">Navigation</p>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {[
            { href: '/', label: 'Home' },
            { href: '/services', label: 'Services' },
            { href: '/about', label: 'About' },
            { href: '/contact', label: 'Contact' },
          ].map(link => (
            <li>
              <a href={link.href} style="color: #9ca3af; font-size: 0.9rem; text-decoration: none;"
                onmouseover="this.style.color='#c0171d'"
                onmouseout="this.style.color='#9ca3af'"
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p style="color: #ffffff; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem;">Get in Touch</p>
        <p style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 0.5rem;">Salt Lake Valley, Utah</p>
        <a href="https://calendly.com/bryan-dutson" target="_blank" rel="noopener noreferrer" style="color: #c0171d; font-size: 0.9rem; text-decoration: none; font-weight: 500;">Schedule a Consultation →</a>
        <div style="margin-top: 1rem;">
          <a
            href="https://www.linkedin.com/company/techopticore-llc/"
            target="_blank"
            rel="noopener noreferrer"
            style="display: inline-flex; align-items: center; gap: 0.4rem; color: #9ca3af; font-size: 0.9rem; text-decoration: none;"
            onmouseover="this.style.color='#c0171d'"
            onmouseout="this.style.color='#9ca3af'"
          >
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>

    </div>

    <div style="border-top: 1px solid #2a2a2a; padding-top: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; align-items: center; text-align: center;">
      <p style="color: #6b7280; font-size: 0.8rem;">
        &copy; {year} TechOptiCore LLC. All rights reserved.
      </p>
    </div>
  </div>
</footer>
