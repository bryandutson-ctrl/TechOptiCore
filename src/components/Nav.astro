---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header style="background-color: #111111; border-bottom: 1px solid #2a2a2a;" class="sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 no-underline">
      <img src="/logo.png" alt="TechOptiCore LLC" style="height: 132px; width: auto;" />
      <span style="font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em; color: #ffffff;">
        <span style="color: #c0171d;">TechOpti</span>Core
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          style={`color: ${currentPath === link.href ? '#c0171d' : '#d1d5db'}; font-size: 0.95rem; font-weight: 500; text-decoration: none; transition: color 0.2s;`}
          onmouseover="this.style.color='#c0171d'"
          onmouseout={`this.style.color='${currentPath === link.href ? '#c0171d' : '#d1d5db'}'`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        style="background-color: #c0171d; color: #ffffff; font-size: 0.9rem; font-weight: 600; padding: 0.5rem 1.25rem; border-radius: 0.375rem; text-decoration: none; transition: background-color 0.2s;"
        onmouseover="this.style.backgroundColor='#8b1013'"
        onmouseout="this.style.backgroundColor='#c0171d'"
      >
        Schedule a Call
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      style="color: #d1d5db; background: none; border: none; cursor: pointer; padding: 0.5rem;"
      class="md:hidden"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden" style="background-color: #1c1c1c; border-top: 1px solid #2a2a2a;">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          style="color: #d1d5db; font-size: 1rem; font-weight: 500; text-decoration: none;"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        style="background-color: #c0171d; color: #ffffff; font-size: 0.9rem; font-weight: 600; padding: 0.6rem 1.25rem; border-radius: 0.375rem; text-decoration: none; text-align: center;"
      >
        Schedule a Call
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
