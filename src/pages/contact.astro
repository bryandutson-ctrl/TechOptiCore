---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Schedule a free 30-minute consultation with TechOptiCore LLC. Salt Lake Valley, Utah."
>

  <!-- Page Header -->
  <section style="background: linear-gradient(135deg, #111111 0%, #1c1c1c 60%, #2a0a0b 100%); padding: 5rem 1.5rem 4rem;">
    <div class="max-w-4xl mx-auto text-center">
      <p style="color: #c0171d; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 1rem;">Contact</p>
      <h1 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: #ffffff; margin-bottom: 1.25rem; letter-spacing: -0.02em;">
        Schedule a Free Consultation
      </h1>
      <p style="color: #9ca3af; font-size: 1.05rem; line-height: 1.7; max-width: 560px; margin: 0 auto;">
        30 minutes. No pitch. We'll listen to your challenges, share honest perspective, and let you decide if it's worth going further.
      </p>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section style="padding: 5rem 1.5rem;">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">

      <!-- Form -->
      <div>
        <h2 style="font-size: 1.3rem; font-weight: 700; color: #ffffff; margin-bottom: 1.75rem;">Send Us a Message</h2>
        <form
          id="contact-form"
          style="display: flex; flex-direction: column; gap: 1.25rem;"
        >
          <div>
            <label for="name" style="display: block; color: #d1d5db; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.4rem;">Your Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Jane Smith"
              style="width: 100%; background-color: #1c1c1c; border: 1px solid #3a3a3a; border-radius: 0.375rem; color: #ffffff; font-size: 0.95rem; padding: 0.7rem 1rem; outline: none; box-sizing: border-box;"
              onfocus="this.style.borderColor='#c0171d'"
              onblur="this.style.borderColor='#3a3a3a'"
            />
          </div>
          <div>
            <label for="email" style="display: block; color: #d1d5db; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.4rem;">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="jane@company.com"
              style="width: 100%; background-color: #1c1c1c; border: 1px solid #3a3a3a; border-radius: 0.375rem; color: #ffffff; font-size: 0.95rem; padding: 0.7rem 1rem; outline: none; box-sizing: border-box;"
              onfocus="this.style.borderColor='#c0171d'"
              onblur="this.style.borderColor='#3a3a3a'"
            />
          </div>
          <div>
            <label for="company" style="display: block; color: #d1d5db; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.4rem;">Company / Organization</label>
            <input
              type="text"
              id="company"
              name="company"
              placeholder="Acme Financial"
              style="width: 100%; background-color: #1c1c1c; border: 1px solid #3a3a3a; border-radius: 0.375rem; color: #ffffff; font-size: 0.95rem; padding: 0.7rem 1rem; outline: none; box-sizing: border-box;"
              onfocus="this.style.borderColor='#c0171d'"
              onblur="this.style.borderColor='#3a3a3a'"
            />
          </div>
          <div>
            <label for="service" style="display: block; color: #d1d5db; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.4rem;">What are you looking for?</label>
            <select
              id="service"
              name="service"
              style="width: 100%; background-color: #1c1c1c; border: 1px solid #3a3a3a; border-radius: 0.375rem; color: #d1d5db; font-size: 0.95rem; padding: 0.7rem 1rem; outline: none; box-sizing: border-box;"
              onfocus="this.style.borderColor='#c0171d'"
              onblur="this.style.borderColor='#3a3a3a'"
            >
              <option value="">Select a service...</option>
              <option value="fractional">Fractional IT Leadership</option>
              <option value="assessment">Technology Assessment</option>
              <option value="cost">Cost Optimization</option>
              <option value="planning">IT Strategic Planning</option>
              <option value="finserv">Financial Services Consulting</option>
              <option value="governance">IT Governance & Compliance</option>
              <option value="unsure">Not sure yet</option>
            </select>
          </div>
          <div>
            <label for="message" style="display: block; color: #d1d5db; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.4rem;">Tell us about your challenge</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="What's the main IT challenge you're trying to solve?"
              style="width: 100%; background-color: #1c1c1c; border: 1px solid #3a3a3a; border-radius: 0.375rem; color: #ffffff; font-size: 0.95rem; padding: 0.7rem 1rem; outline: none; resize: vertical; box-sizing: border-box;"
              onfocus="this.style.borderColor='#c0171d'"
              onblur="this.style.borderColor='#3a3a3a'"
            ></textarea>
          </div>
          <button
            type="submit"
            style="background-color: #c0171d; color: #ffffff; font-weight: 700; font-size: 1rem; padding: 0.85rem 2rem; border-radius: 0.4rem; border: none; cursor: pointer; width: 100%;"
            onmouseover="this.style.backgroundColor='#8b1013'"
            onmouseout="this.style.backgroundColor='#c0171d'"
          >
            Send Message
          </button>
          <p id="form-status" style="display: none; text-align: center; font-size: 0.9rem; color: #9ca3af;"></p>
        </form>
      </div>

      <!-- Info -->
      <div>
        <h2 style="font-size: 1.3rem; font-weight: 700; color: #ffffff; margin-bottom: 1.75rem;">What to Expect</h2>
        <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem;">
          {[
            { step: '01', title: 'Submit Your Info', body: 'Fill out the form with a bit of context on your situation. We\'ll review before we connect.' },
            { step: '02', title: '30-Minute Consultation', body: 'We listen first. You\'ll get honest perspective on your challenges and whether TechOptiCore is the right fit.' },
            { step: '03', title: 'Custom Proposal', body: 'If there\'s a fit, we\'ll put together a scoped proposal tailored to your specific needs and budget.' },
          ].map(item => (
            <div style="display: flex; gap: 1.25rem; align-items: flex-start;">
              <div style="background-color: #c0171d; color: #ffffff; font-size: 0.75rem; font-weight: 700; width: 2rem; height: 2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                {item.step}
              </div>
              <div>
                <p style="color: #ffffff; font-weight: 600; font-size: 0.95rem; margin-bottom: 0.3rem;">{item.title}</p>
                <p style="color: #9ca3af; font-size: 0.88rem; line-height: 1.6;">{item.body}</p>
              </div>
            </div>
          ))}
        </div>

        <div style="background-color: #1c1c1c; border: 1px solid #2a2a2a; border-radius: 0.75rem; padding: 1.75rem;">
          <p style="color: #ffffff; font-weight: 700; font-size: 0.9rem; margin-bottom: 1rem;">TechOptiCore LLC</p>
          <p style="color: #9ca3af; font-size: 0.88rem; line-height: 1.6;">Salt Lake Valley, Utah</p>
          <p style="color: #9ca3af; font-size: 0.88rem; line-height: 1.6; margin-top: 0.5rem;">Serving organizations across Utah and nationally.</p>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'Sending...';
    btn.disabled = true;

    // Formspree endpoint — replace YOUR_FORM_ID with the actual ID after setup
    const res = await fetch('https://formspree.io/f/YOUR_FORM_ID', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: new FormData(form),
    });

    if (res.ok) {
      form.reset();
      btn.style.display = 'none';
      status.style.display = 'block';
      status.style.color = '#4ade80';
      status.textContent = "Message sent! We'll be in touch within one business day.";
    } else {
      btn.textContent = 'Send Message';
      btn.disabled = false;
      status.style.display = 'block';
      status.style.color = '#f87171';
      status.textContent = 'Something went wrong. Please try again or email us directly.';
    }
  });
</script>
